{
  "schemaVersion": 1,
  "version": "2026.07.4-burp",
  "releasedAt": "2026-07-16",
  "rules": [
    {
      "id": "aws-access-key-id",
      "name": "AWS access key ID",
      "kind": "SECRET",
      "severity": "HIGH",
      "confidence": "HIGH",
      "keywords": ["AKIA", "ASIA"],
      "regex": "\\b((?:AKIA|ASIA)[A-Z0-9]{16})\\b",
      "secretGroup": 1,
      "minLength": 20,
      "allowlistRegex": "(?i)(example|sample|test|x{6,})"
    },
    {
      "id": "aws-secret-access-key",
      "name": "AWS secret access key assignment",
      "kind": "SECRET",
      "severity": "CRITICAL",
      "confidence": "HIGH",
      "keywords": ["aws_secret_access_key", "secretaccesskey"],
      "regex": "(?i)(?:aws[_-]?secret[_-]?access[_-]?key|secretAccessKey)\\s*[:=]\\s*['\"]([A-Za-z0-9/+=]{40})['\"]",
      "secretGroup": 1,
      "minEntropy": 3.5,
      "minLength": 40
    },
    {
      "id": "github-token",
      "name": "GitHub token",
      "kind": "SECRET",
      "severity": "CRITICAL",
      "confidence": "HIGH",
      "keywords": ["ghp_", "gho_", "ghu_", "ghs_", "ghr_", "github_pat_"],
      "regex": "\\b((?:gh[pousr]_[A-Za-z0-9_]{30,255}|github_pat_[A-Za-z0-9_]{20,255}))\\b",
      "secretGroup": 1,
      "minEntropy": 3.0
    },
    {
      "id": "gitlab-token",
      "name": "GitLab token",
      "kind": "SECRET",
      "severity": "CRITICAL",
      "confidence": "HIGH",
      "keywords": ["glpat-", "glrt-", "gldt-"],
      "regex": "\\b((?:glpat|glrt|gldt)-[A-Za-z0-9_-]{20,255})\\b",
      "secretGroup": 1,
      "minEntropy": 3.0
    },
    {
      "id": "stripe-secret-key",
      "name": "Stripe secret or restricted key",
      "kind": "SECRET",
      "severity": "CRITICAL",
      "confidence": "HIGH",
      "keywords": ["sk_live_", "rk_live_"],
      "regex": "\\b((?:sk|rk)_live_[A-Za-z0-9]{16,255})\\b",
      "secretGroup": 1
    },
    {
      "id": "slack-token",
      "name": "Slack token",
      "kind": "SECRET",
      "severity": "CRITICAL",
      "confidence": "HIGH",
      "keywords": ["xoxb-", "xoxp-", "xoxa-", "xoxr-", "xapp-"],
      "regex": "\\b((?:xox[aboprs]-[A-Za-z0-9-]{10,250}|xapp-[A-Za-z0-9-]{10,250}))\\b",
      "secretGroup": 1
    },
    {
      "id": "google-api-key",
      "name": "Google API key",
      "kind": "SECRET",
      "severity": "HIGH",
      "confidence": "HIGH",
      "keywords": ["AIza"],
      "regex": "\\b(AIza[A-Za-z0-9_-]{35})\\b",
      "secretGroup": 1
    },
    {
      "id": "firebase-server-key",
      "name": "Firebase/FCM server key",
      "kind": "SECRET",
      "severity": "CRITICAL",
      "confidence": "HIGH",
      "keywords": ["AAAA"],
      "regex": "\\b(AAAA[A-Za-z0-9_-]{7}:[A-Za-z0-9_-]{100,200})\\b",
      "secretGroup": 1,
      "minEntropy": 3.5
    },
    {
      "id": "openai-api-key",
      "name": "OpenAI API key",
      "kind": "SECRET",
      "severity": "CRITICAL",
      "confidence": "HIGH",
      "keywords": ["sk-proj-", "sk-svcacct-"],
      "regex": "\\b((?:sk-proj-|sk-svcacct-)[A-Za-z0-9_-]{20,255})\\b",
      "secretGroup": 1,
      "minEntropy": 3.0
    },
    {
      "id": "anthropic-api-key",
      "name": "Anthropic API key",
      "kind": "SECRET",
      "severity": "CRITICAL",
      "confidence": "HIGH",
      "keywords": ["sk-ant-"],
      "regex": "\\b(sk-ant-[A-Za-z0-9_-]{20,255})\\b",
      "secretGroup": 1,
      "minEntropy": 3.0
    },
    {
      "id": "huggingface-token",
      "name": "Hugging Face token",
      "kind": "SECRET",
      "severity": "HIGH",
      "confidence": "HIGH",
      "keywords": ["hf_"],
      "regex": "\\b(hf_[A-Za-z0-9]{30,255})\\b",
      "secretGroup": 1,
      "minEntropy": 3.0
    },
    {
      "id": "sendgrid-api-key",
      "name": "SendGrid API key",
      "kind": "SECRET",
      "severity": "CRITICAL",
      "confidence": "HIGH",
      "keywords": ["SG."],
      "regex": "\\b(SG\\.[A-Za-z0-9_-]{16,32}\\.[A-Za-z0-9_-]{32,100})\\b",
      "secretGroup": 1
    },
    {
      "id": "twilio-api-key",
      "name": "Twilio API key",
      "kind": "SECRET",
      "severity": "HIGH",
      "confidence": "HIGH",
      "keywords": ["SK"],
      "regex": "\\b(SK[0-9a-fA-F]{32})\\b",
      "secretGroup": 1
    },
    {
      "id": "jwt-token",
      "name": "JSON Web Token",
      "kind": "SECRET",
      "severity": "HIGH",
      "confidence": "HIGH",
      "keywords": ["eyJ"],
      "regex": "\\b(eyJ[A-Za-z0-9_-]{5,}\\.eyJ[A-Za-z0-9_-]{5,}\\.[A-Za-z0-9_-]{8,})\\b",
      "secretGroup": 1
    },
    {
      "id": "private-key",
      "name": "Private key block",
      "kind": "SECRET",
      "severity": "CRITICAL",
      "confidence": "HIGH",
      "keywords": ["PRIVATE KEY"],
      "regex": "(?s)(-----BEGIN (?:RSA |EC |OPENSSH |DSA )?PRIVATE KEY-----.*?-----END (?:RSA |EC |OPENSSH |DSA )?PRIVATE KEY-----)",
      "secretGroup": 1,
      "minLength": 80
    },
    {
      "id": "basic-auth-url",
      "name": "Credentials embedded in URL",
      "kind": "CREDENTIAL",
      "severity": "CRITICAL",
      "confidence": "HIGH",
      "keywords": ["http://", "https://"],
      "regex": "(?i)\\b(?:https?)://([^/@:'\"\\s]{1,128}:[^/@'\"\\s]{1,256})@[^\\s'\"<>]+",
      "secretGroup": 1,
      "minLength": 3,
      "allowlistRegex": "(?i)(user:pass|username:password|example|placeholder)"
    },
    {
      "id": "database-connection-uri",
      "name": "Database connection URI with credentials",
      "kind": "CREDENTIAL",
      "severity": "CRITICAL",
      "confidence": "HIGH",
      "keywords": ["mongodb://", "postgres://", "postgresql://", "mysql://", "redis://", "amqp://"],
      "regex": "(?i)\\b((?:mongodb(?:\\+srv)?|postgres(?:ql)?|mysql|mariadb|redis|amqps?)://[^\\s'\"<>]{3,1000})",
      "secretGroup": 1,
      "minLength": 12,
      "allowlistRegex": "(?i)(localhost|127\\.0\\.0\\.1|username:password|user:pass|example\\.(com|org))"
    },
    {
      "id": "generic-api-secret",
      "name": "Generic API key or secret assignment",
      "kind": "SECRET",
      "severity": "HIGH",
      "confidence": "MEDIUM",
      "keywords": ["api_key", "apikey", "api-secret", "client_secret", "access_token", "auth_token", "secret_key"],
      "regex": "(?i)(?:api[_-]?key|api[_-]?secret|client[_-]?secret|access[_-]?token|auth[_-]?token|secret[_-]?key)\\s*[:=]\\s*['\"]([A-Za-z0-9_./+=:-]{16,512})['\"]",
      "secretGroup": 1,
      "minEntropy": 3.0,
      "minLength": 16,
      "allowlistRegex": "(?i)^(?:example|sample|test|demo|placeholder|changeme|your[_-]?[a-z_-]+|[x*]{8,}|undefined|null|process\\.env.*)$"
    },
    {
      "id": "hardcoded-password",
      "name": "Hardcoded password",
      "kind": "CREDENTIAL",
      "severity": "HIGH",
      "confidence": "MEDIUM",
      "keywords": ["password", "passwd", "pwd"],
      "regex": "(?i)(?:password|passwd|pwd)\\s*[:=]\\s*['\"]([^'\"\\r\\n]{6,256})['\"]",
      "secretGroup": 1,
      "minLength": 6,
      "allowlistRegex": "(?i)^(?:password|passwd|changeme|example|sample|test|demo|placeholder|your[_-]?password|[x*]{6,}|\\$\\{|<.*>)$"
    },
    {
      "id": "hardcoded-username",
      "name": "Hardcoded username or account identifier",
      "kind": "IDENTIFIER",
      "severity": "MEDIUM",
      "confidence": "MEDIUM",
      "keywords": ["username", "user_name", "admin_user", "account_id"],
      "regex": "(?i)(?:user[_-]?name|admin[_-]?user|account[_-]?id)\\s*[:=]\\s*['\"]([^'\"\\r\\n]{3,128})['\"]",
      "secretGroup": 1,
      "minLength": 3,
      "allowlistRegex": "(?i)^(?:username|user|admin|example|sample|test|demo|placeholder|currentUser|undefined|null)$"
    },
    {
      "id": "authorization-bearer-literal",
      "name": "Hardcoded Authorization bearer value",
      "kind": "CREDENTIAL",
      "severity": "CRITICAL",
      "confidence": "HIGH",
      "keywords": ["Bearer "],
      "regex": "(?i)Bearer\\s+([A-Za-z0-9._~+/-]{16,1000})",
      "secretGroup": 1,
      "minEntropy": 2.8,
      "allowlistRegex": "(?i)^(?:token|your[_-]?token|example|placeholder|\\$\\{.*)$"
    },
    {
      "id": "webhook-url",
      "name": "Webhook URL",
      "kind": "SECRET",
      "severity": "HIGH",
      "confidence": "HIGH",
      "keywords": ["hooks.slack.com", "discord.com/api/webhooks", "office.com/webhook"],
      "regex": "(?i)(https://(?:hooks\\.slack\\.com/services|(?:discord(?:app)?\\.com)/api/webhooks|[^/]*office\\.com/webhook)/[^\\s'\"<>]{12,1000})",
      "secretGroup": 1
    },
    {
      "id": "admin-debug-route",
      "name": "Administrative or debug route",
      "kind": "ENDPOINT",
      "severity": "MEDIUM",
      "confidence": "MEDIUM",
      "keywords": ["/admin", "/debug", "/internal", "/manage", "/actuator", "/console"],
      "regex": "(?i)(/(?:admin|administrator|debug|internal|manage|management|actuator|console|backoffice|superuser)(?:/[A-Za-z0-9._~!$&()*+,;=:@%/-]*)?)",
      "secretGroup": 1,
      "minLength": 5
    },
    {
      "id": "api-endpoint",
      "name": "API endpoint",
      "kind": "ENDPOINT",
      "severity": "INFO",
      "confidence": "MEDIUM",
      "keywords": ["/api/", "/v1/", "/v2/", "/v3/"],
      "regex": "(?i)(/(?:api/)?v[0-9]+/[A-Za-z0-9._~!$&()*+,;=:@%/?=-]{2,512}|/api/[A-Za-z0-9._~!$&()*+,;=:@%/?=-]{2,512})",
      "secretGroup": 1,
      "minLength": 5
    },
    {
      "id": "graphql-endpoint",
      "name": "GraphQL endpoint",
      "kind": "ENDPOINT",
      "severity": "MEDIUM",
      "confidence": "HIGH",
      "keywords": ["graphql", "graphiql"],
      "regex": "(?i)((?:https?://[^\\s'\"<>]+)?/(?:graphql|graphiql)(?:[/?][^\\s'\"<>]*)?)",
      "secretGroup": 1
    },
    {
      "id": "websocket-endpoint",
      "name": "WebSocket endpoint",
      "kind": "ENDPOINT",
      "severity": "MEDIUM",
      "confidence": "HIGH",
      "keywords": ["ws://", "wss://"],
      "regex": "(?i)\\b((?:ws|wss)://[^\\s'\"<>]{3,1000})",
      "secretGroup": 1
    },
    {
      "id": "linkfinder-endpoint",
      "name": "Quoted application endpoint",
      "kind": "ENDPOINT",
      "severity": "INFO",
      "confidence": "LOW",
      "keywords": [],
      "regex": "(?i)[\"'`]((?:(?:https?:)?//[A-Za-z0-9.-]+\\.[A-Za-z]{2,}(?::[0-9]{1,5})?(?:/[A-Za-z0-9._~!$&()*+,;=:@%/?#-]{0,1000})?|(?:/|\\.\\.?/)[A-Za-z0-9._~!$&()*+,;=:@%/?#-]{2,1000}|[A-Za-z0-9_-]+(?:/[A-Za-z0-9._~!$&()*+,;=:@%?#-]+)+\\.(?:php|asp|aspx|jsp|json|action|html?|xml|txt)(?:[?#][A-Za-z0-9._~!$&()*+,;=:@%/?#-]*)?))[\"'`]",
      "secretGroup": 1,
      "minLength": 3,
      "allowlistRegex": "(?i)\\.(?:js|mjs|cjs|css|png|jpe?g|gif|svg|ico|webp|avif|woff2?|ttf|eot|map)(?:[?#].*)?$"
    },
    {
      "id": "internal-hostname-url",
      "name": "Internal or local service URL",
      "kind": "CONFIGURATION",
      "severity": "MEDIUM",
      "confidence": "MEDIUM",
      "keywords": ["localhost", ".local", ".internal", "127.0.0.1", "10."],
      "regex": "(?i)\\b((?:https?|wss?)://(?:localhost|127\\.0\\.0\\.1|10\\.[0-9.]+|192\\.168\\.[0-9.]+|172\\.(?:1[6-9]|2[0-9]|3[01])\\.[0-9.]+|[A-Za-z0-9.-]+\\.(?:local|internal))(?::[0-9]{1,5})?[^\\s'\"<>]*)",
      "secretGroup": 1
    },
    {
      "id": "sensitive-config-file",
      "name": "Sensitive configuration file reference",
      "kind": "CONFIGURATION",
      "severity": "MEDIUM",
      "confidence": "MEDIUM",
      "keywords": [".env", "config.json", "credentials", "secrets"],
      "regex": "(?i)(/(?:[^\\s'\"<>/]+/)*(?:\\.env(?:\\.[A-Za-z0-9_-]+)?|config\\.(?:json|ya?ml)|credentials\\.(?:json|ya?ml)|secrets?\\.(?:json|ya?ml)))",
      "secretGroup": 1
    },
    {
      "id": "cloud-storage-url",
      "name": "Cloud storage location",
      "kind": "CONFIGURATION",
      "severity": "MEDIUM",
      "confidence": "HIGH",
      "keywords": ["amazonaws.com", "storage.googleapis.com", "blob.core.windows.net"],
      "regex": "(?i)\\b(https://[^\\s'\"<>]*(?:s3[.-][^/]*amazonaws\\.com|storage\\.googleapis\\.com|blob\\.core\\.windows\\.net)[^\\s'\"<>]*)",
      "secretGroup": 1
    },
    {
      "id": "npm-access-token",
      "name": "npm access token",
      "kind": "SECRET",
      "severity": "CRITICAL",
      "confidence": "HIGH",
      "keywords": ["npm_"],
      "regex": "\\b(npm_[A-Za-z0-9]{30,100})\\b",
      "secretGroup": 1,
      "minEntropy": 3.0
    },
    {
      "id": "pypi-upload-token",
      "name": "PyPI upload token",
      "kind": "SECRET",
      "severity": "CRITICAL",
      "confidence": "HIGH",
      "keywords": ["pypi-AgEI"],
      "regex": "\\b(pypi-AgEI[A-Za-z0-9_-]{50,255})\\b",
      "secretGroup": 1
    },
    {
      "id": "shopify-access-token",
      "name": "Shopify access token",
      "kind": "SECRET",
      "severity": "CRITICAL",
      "confidence": "HIGH",
      "keywords": ["shpat_", "shpca_", "shppa_", "shpss_"],
      "regex": "\\b((?:shpat|shpca|shppa|shpss)_[0-9a-fA-F]{32})\\b",
      "secretGroup": 1
    },
    {
      "id": "digitalocean-token",
      "name": "DigitalOcean personal access token",
      "kind": "SECRET",
      "severity": "CRITICAL",
      "confidence": "HIGH",
      "keywords": ["dop_v1_"],
      "regex": "\\b(dop_v1_[0-9a-fA-F]{64})\\b",
      "secretGroup": 1
    },
    {
      "id": "postman-api-key",
      "name": "Postman API key",
      "kind": "SECRET",
      "severity": "HIGH",
      "confidence": "HIGH",
      "keywords": ["PMAK-"],
      "regex": "\\b(PMAK-[A-Za-z0-9_-]{20,100})\\b",
      "secretGroup": 1
    },
    {
      "id": "new-relic-api-key",
      "name": "New Relic API key",
      "kind": "SECRET",
      "severity": "HIGH",
      "confidence": "HIGH",
      "keywords": ["NRAK-"],
      "regex": "\\b(NRAK-[A-Z0-9]{20,100})\\b",
      "secretGroup": 1
    },
    {
      "id": "grafana-service-token",
      "name": "Grafana service account token",
      "kind": "SECRET",
      "severity": "CRITICAL",
      "confidence": "HIGH",
      "keywords": ["glsa_"],
      "regex": "\\b(glsa_[A-Za-z0-9_-]{20,255})\\b",
      "secretGroup": 1
    },
    {
      "id": "telegram-bot-token",
      "name": "Telegram bot token",
      "kind": "SECRET",
      "severity": "CRITICAL",
      "confidence": "HIGH",
      "keywords": ["bot_token", "telegram"],
      "regex": "\\b([0-9]{6,12}:[A-Za-z0-9_-]{30,50})\\b",
      "secretGroup": 1,
      "minEntropy": 3.0
    },
    {
      "id": "azure-storage-account-key",
      "name": "Azure storage account key",
      "kind": "SECRET",
      "severity": "CRITICAL",
      "confidence": "HIGH",
      "keywords": ["AccountKey=", "account_key"],
      "regex": "(?i)(?:AccountKey|account[_-]?key)\\s*[=:]\\s*['\"]?([A-Za-z0-9+/]{80,100}={0,2})",
      "secretGroup": 1,
      "minEntropy": 4.0
    },
    {
      "id": "azure-sas-token",
      "name": "Azure shared access signature",
      "kind": "SECRET",
      "severity": "HIGH",
      "confidence": "HIGH",
      "keywords": ["sig=", "sv="],
      "regex": "(?i)((?:sv|se|sp)=[^\\s'\"&]{1,200}(?:&(?:sv|se|sp|sr|sig)=[^\\s'\"&]{1,500}){2,10})",
      "secretGroup": 1
    },
    {
      "id": "sentry-dsn",
      "name": "Sentry DSN",
      "kind": "CONFIGURATION",
      "severity": "MEDIUM",
      "confidence": "HIGH",
      "keywords": ["sentry", "ingest.sentry.io"],
      "regex": "(?i)\\b(https://[0-9a-f]{16,64}(?::[0-9a-f]{16,64})?@[A-Za-z0-9.-]*sentry\\.io/[0-9]+)\\b",
      "secretGroup": 1,
      "sensitiveValue": true
    },
    {
      "id": "dom-xss-html-sink",
      "name": "Potential DOM XSS HTML injection sink",
      "kind": "VULNERABILITY",
      "severity": "HIGH",
      "confidence": "LOW",
      "keywords": ["innerhtml", "outerhtml", "insertadjacenthtml", "document.write"],
      "regex": "(?i)\\b((?:innerHTML|outerHTML)\\s*=|insertAdjacentHTML\\s*\\(|document\\.write(?:ln)?\\s*\\()",
      "secretGroup": 1,
      "description": "A JavaScript HTML-writing sink was found. It becomes DOM XSS when attacker-controlled data can reach it without context-appropriate sanitization.",
      "remediation": "Trace the value reaching this sink. Prefer textContent or safe DOM construction, and sanitize unavoidable HTML with a maintained policy-based sanitizer."
    },
    {
      "id": "dynamic-code-execution-sink",
      "name": "Dynamic JavaScript execution sink",
      "kind": "VULNERABILITY",
      "severity": "HIGH",
      "confidence": "LOW",
      "keywords": ["eval(", "new function"],
      "regex": "(?i)\\b((?:eval\\s*\\(|new\\s+Function\\s*\\())",
      "secretGroup": 1,
      "description": "The application dynamically compiles or evaluates JavaScript. User-controlled input reaching this sink can lead to script execution.",
      "remediation": "Remove eval and Function construction. Replace dynamic code with explicit parsing, dispatch tables, or structured data handling."
    },
    {
      "id": "client-open-redirect-flow",
      "name": "Potential client-side open redirect flow",
      "kind": "VULNERABILITY",
      "severity": "HIGH",
      "confidence": "LOW",
      "keywords": ["urlsearchparams", "location.search", "location.hash", "document.url"],
      "regex": "(?is)\\b((?:window\\.)?location(?:\\.href)?\\s*=|(?:window\\.)?location\\.(?:assign|replace)\\s*\\()\\s*[^;\\r\\n]{0,240}(?:URLSearchParams|location\\.(?:search|hash)|document\\.URL)",
      "secretGroup": 1,
      "description": "A navigation sink appears to consume data derived from the current URL. Insufficient destination validation can create a client-side open redirect.",
      "remediation": "Resolve destinations against a fixed trusted origin and allowlist exact paths or hosts. Reject scheme-relative, encoded, and non-HTTP destinations."
    },
    {
      "id": "wildcard-postmessage-target",
      "name": "Wildcard postMessage target origin",
      "kind": "VULNERABILITY",
      "severity": "MEDIUM",
      "confidence": "MEDIUM",
      "keywords": ["postmessage"],
      "regex": "(?i)\\bpostMessage\\s*\\([^\\r\\n;]{0,500},\\s*(['\"]\\*['\"])\\s*\\)",
      "secretGroup": 1,
      "description": "A cross-window message is sent to every origin. A malicious page may receive sensitive message data if it can obtain a window reference.",
      "remediation": "Use the exact expected target origin and validate both event.origin and event.source when receiving messages."
    },
    {
      "id": "disabled-tls-verification",
      "name": "TLS certificate verification disabled",
      "kind": "VULNERABILITY",
      "severity": "HIGH",
      "confidence": "HIGH",
      "keywords": ["rejectunauthorized", "node_tls_reject_unauthorized"],
      "regex": "(?i)\\b((?:rejectUnauthorized\\s*[:=]\\s*false|NODE_TLS_REJECT_UNAUTHORIZED\\s*[:=]\\s*['\"]?0['\"]?))",
      "secretGroup": 1,
      "description": "The code disables TLS certificate verification, allowing a network attacker to impersonate upstream services.",
      "remediation": "Keep certificate verification enabled. Configure the correct trust store or a narrowly scoped custom CA instead of bypassing validation."
    },
    {
      "id": "sensitive-browser-storage",
      "name": "Sensitive value stored in Web Storage",
      "kind": "VULNERABILITY",
      "severity": "MEDIUM",
      "confidence": "MEDIUM",
      "keywords": ["localstorage", "sessionstorage"],
      "regex": "(?i)\\b(?:localStorage|sessionStorage)\\s*\\.\\s*setItem\\s*\\(\\s*['\"]((?:access|auth|id|refresh)[_-]?token|jwt|password|secret|session)['\"]",
      "secretGroup": 1,
      "description": "A key name associated with authentication or secrets is written to browser Web Storage, where any same-origin script can read it.",
      "remediation": "Prefer Secure, HttpOnly, SameSite cookies for session credentials and keep short-lived sensitive state out of Web Storage."
    },
    {
      "id": "prototype-pollution-dangerous-key",
      "name": "Prototype-pollution dangerous property access",
      "kind": "VULNERABILITY",
      "severity": "MEDIUM",
      "confidence": "LOW",
      "keywords": ["__proto__", "constructor.prototype"],
      "regex": "(?i)\\b(__proto__|constructor\\s*\\.\\s*prototype)\\b",
      "secretGroup": 1,
      "description": "A prototype-mutating property is referenced. Unsafe recursive merges or attacker-controlled property paths may make this exploitable.",
      "remediation": "Reject __proto__, prototype, and constructor keys, use own-property checks, and update vulnerable merge or path-setting libraries."
    },
    {
      "id": "cleartext-websocket-transport",
      "name": "Cleartext WebSocket transport",
      "kind": "VULNERABILITY",
      "severity": "MEDIUM",
